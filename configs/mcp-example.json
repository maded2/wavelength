{
  "server": {
    "port": 3000
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4",
    "endpoint": "https://api.openai.com/v1",
    "api_key": "your-api-key-here",
    "temperature": 0.7,
    "timeout": 60,
    "path": "/chat/completions"
  },
  "persona": {
    "system_prompt": ""
  },
  "mcp": {
    "servers": [
      {
        "name": "filesystem",
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/user/projects"],
        "timeout": 10
      },
      {
        "name": "web_search",
        "transport": "sse",
        "url": "http://localhost:3001/sse",
        "timeout": 15
      }
    ]
  },
  "data_dir": "./data"
}
